{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "paths": {
      "main": ["./main.ts"],
      "__mocks__/*": ["./__mocks__/*"],
      "src/*": ["./src/*"],
      "tests/*": ["./tests/*"]
    },

    "types": ["bun-types", "node"],
    "allowJs": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "sourceMap": true,
    "inlineSources": true,
    "lib": ["DOM", "ES2017"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
